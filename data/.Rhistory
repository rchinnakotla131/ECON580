for(i in 1:500){
X <- runif(30, min=10, max=20)
Y <- 10 + 2 * X + rnorm(30, mean=0, sd=5)
if(i==1){
plot(X,Y)
}
linearFit <- lm(Y~X)
abline(linearFit, col=rgb(0,0,0,.1))
slopes[i] <- coef(linearFit)[2]
intercepts[i] <- coef(linearFit)[1]
}
