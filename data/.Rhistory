return(mean(beta1hat))
}
estimate_beta1hat_variance(100, 4, 1000)
estimate_beta1hat_variance <- function(n, sigma2, M){
beta1hat <- numeric(M)
for (i in 1:M) {
beta1hat[i] <- (0.5 - mean(generate_and_estimate(n, sigma2)))^2
}
return(mean(beta1hat))
}
