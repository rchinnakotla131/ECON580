mutate(
District = case_when(
dist_code == 5  ~ "Bharuch",
dist_code == 23 ~ "Sabarkantha",
dist_code == 26 ~ "Ahwa-Dang",
TRUE ~ District
),
total_muslim_destroyed = case_when(
dist_code == 5  ~ 7,
dist_code == 23 ~ 0,
dist_code == 26 ~ 0,
TRUE ~ total_muslim_destroyed
),
pct_gujarati = case_when(
dist_code == 5  ~ 84.97,
dist_code == 23 ~ 97.85,
TRUE ~ pct_gujarati
),
total_persons = case_when(
dist_code == 5  ~ 1370104,
dist_code == 23 ~ 2083416,
dist_code == 26 ~ 186712,
TRUE ~ total_persons
)
)
new_final <- summary_df %>%
left_join(housing, by = "dist_code") %>%
filter(dist_code != 21)
new_final <- new_final %>%
mutate(
muslim_destroyed_per_capita    = total_muslim_destroyed / total_persons,
good_housing_per_capita        = total_good             / total_persons,
livable_housing_per_capita     = total_livable          / total_persons,
dilapidated_housing_per_capita = total_dilapidated      / total_persons,
pct_dilapidated                = total_dilapidated      / total_total   * 100
)
View(new_final %>% select(District, total_muslim_destroyed))
View(new_final %>% select(District, total_muslim_destroyed, muslim_destroyed_per_capita))
View(new_final %>% select(District, total_muslim_destroyed, muslim_destroyed_per_capita * 100000))
# Chunk 1: setup
knitr::opts_chunk$set(echo = TRUE)
library(tidyr)
library(dplyr)
library(readxl)
library(ggplot2)
library(broom)
library(readr)
# Chunk 2: language
language <- read_excel("language_mother_tounge_city.xls") %>%
select(-...9, -...10, -...12, -...13, -...15, -...16)
language <- language[-1, ]
colnames(language) <- language[1, ]
language <- language[-1, ] %>%
drop_na() %>%
filter(grepl("000$", MOTHER)) %>%
group_by(TOWN) %>%
mutate(TOWN    = as.numeric(TOWN),
TOTAL   = as.numeric(TOTAL),
PERCENT = round(TOTAL / sum(TOTAL) * 100, 5))
# Chunk 3: towns
towns <- read_excel("town_directory.xls") %>%
select(DIST_CODE, THSIL_CODE, TOWN_CODE, TOWN_NAME, CLASS, C_STATUS, AREA, POP_2001, DENSITY) %>%
rename(TOWN = TOWN_CODE) %>%
drop_na() %>%
mutate(TOWN     = as.numeric(TOWN),
AREA     = as.numeric(AREA),
POP_2001 = as.numeric(POP_2001),
DENSITY  = as.numeric(DENSITY))
# Chunk 4: religion
raw <- read_excel("religion_town.xls", col_names = FALSE, skip = 4)
colnames(raw) <- c(
"table_name", "state_code", "dist_code", "tehsil_code", "town_code", "area_name",
"total_rural_urban",
"total_persons", "total_males", "total_females",
"hindu_persons", "hindu_males", "hindu_females",
"muslim_persons", "muslim_males", "muslim_females",
"christian_persons", "christian_males", "christian_females",
"sikh_persons", "sikh_males", "sikh_females",
"buddhist_persons", "buddhist_males", "buddhist_females",
"jain_persons", "jain_males", "jain_females",
"other_religion_persons", "other_religion_males", "other_religion_females",
"religion_not_stated_persons", "religion_not_stated_males", "religion_not_stated_females"
)
religion_clean <- raw %>%
filter(!is.na(area_name), area_name != "") %>%
filter(!total_persons %in% c("1", "Persons")) %>%
mutate(across(c(dist_code, state_code, tehsil_code, town_code), as.numeric)) %>%
filter(dist_code != 0 & town_code != 0) %>%
mutate(across(total_persons:religion_not_stated_females, as.numeric))
religion_district <- raw %>%
filter(!is.na(area_name), area_name != "") %>%
filter(!total_persons %in% c("1", "Persons")) %>%
mutate(across(c(dist_code, state_code, tehsil_code, town_code), as.numeric)) %>%
filter(dist_code %in% c(5, 23, 26) & town_code == 0 & tehsil_code == 0) %>%
mutate(across(total_persons:religion_not_stated_females, as.numeric))
# Chunk 5: riots
riots <- read.csv("communal_riots_table.csv") %>%
mutate(across(everything(), ~replace_na(., 0))) %>%
mutate(dist_code = case_when(
District %in% c("A'bad City",    "A'bad Rural")                        ~ 7,
District %in% c("Vadodara City", "Vadodara Rural", "Westpol Vadodara") ~ 19,
District %in% c("Surat City",    "Surat Rural")                        ~ 18,
District %in% c("Rajkot City",   "Rajkot Rural")                       ~ 22,
District == "Anand"         ~ 2,
District == "Godhra"        ~ 16,
District == "Sabarkantha"   ~ 23,
District == "Kheda"         ~ 10,
District == "Mehsana"       ~ 13,
District == "Banaskantha"   ~ 4,
District == "Bharuch"       ~ 5,
District == "Gandhinagar"   ~ 6,
District == "Amreli"        ~ 1,
District == "Junagadh"      ~ 9,
District == "Dahod"         ~ 8,
District == "Narmada"       ~ 14,
District == "Patan"         ~ 17,
District == "Ahwa-Dang"     ~ 26,
District == "Jamnagar"      ~ 11,
District == "Navsari"       ~ 15,
District == "Porbandar"     ~ 20,
District == "Valsad"        ~ 25,
District == "Surendranagar" ~ 24,
District == "Bhavnagar"     ~ 3,
District == "Kutch-Bhuj"    ~ 12,
TRUE ~ NA_real_
)) %>%
filter(!is.na(dist_code)) %>%
mutate(District = case_when(
dist_code == 7  ~ "Ahmedabad",
dist_code == 19 ~ "Vadodara",
dist_code == 18 ~ "Surat",
dist_code == 22 ~ "Rajkot",
TRUE ~ District
)) %>%
filter(Sr_No != "Total") %>%
group_by(dist_code, District) %>%
summarise(
Dargah       = sum(Dargah,       na.rm = TRUE),
Masjid       = sum(Masjid,       na.rm = TRUE),
Madresa      = sum(Madresa,      na.rm = TRUE),
Temple       = sum(Temple,       na.rm = TRUE),
Church       = sum(Church,       na.rm = TRUE),
Total        = sum(Total,        na.rm = TRUE),
Repaired     = sum(Repaired,     na.rm = TRUE),
Not_Repaired = sum(Not_Repaired, na.rm = TRUE),
.groups = "drop"
)
# Chunk 6: combine
combined <- religion_clean %>%
inner_join(language, by = c("town_code" = "TOWN")) %>%
inner_join(towns,   by = c("town_code" = "TOWN"))
clean_combine <- combined %>%
select(table_name, area_name, town_code, state_code, dist_code,
total_persons, hindu_persons, muslim_persons, christian_persons,
sikh_persons, jain_persons, buddhist_persons, other_religion_persons,
`MOTHER TONGUE`, PERCENT, AREA, DENSITY) %>%
group_by(town_code) %>%
mutate(pop_per_person = total_persons / AREA,
total_persons  = as.numeric(total_persons),
hindu_persons  = as.numeric(hindu_persons),
muslim_persons = as.numeric(muslim_persons)) %>%
drop_na()
missing_districts <- religion_district %>%
select(table_name, area_name, town_code, state_code, dist_code,
total_persons, hindu_persons, muslim_persons, christian_persons,
sikh_persons, jain_persons, buddhist_persons, other_religion_persons) %>%
mutate(
`MOTHER TONGUE` = "5 GUJARATI",
PERCENT         = NA_real_,
AREA            = NA_real_,
DENSITY         = NA_real_,
pop_per_person  = NA_real_,
total_persons   = as.numeric(total_persons),
hindu_persons   = as.numeric(hindu_persons),
muslim_persons  = as.numeric(muslim_persons)
)
clean_combine <- bind_rows(clean_combine, missing_districts)
# Chunk 7: housing
housing <- read.csv("gujarat_housing_composition.csv", header = FALSE, check.names = FALSE) %>%
slice(6:n()) %>%
select(1:13) %>%
rename(
table_name        = V1,
state_code        = V2,
dist_code         = V3,
tehsil_city_code  = V4,
area_name         = V5,
total_rural_urban = V6,
total_total       = V7,
total_good        = V8,
total_livable     = V9,
total_dilapidated = V10,
residence_total   = V11,
residence_good    = V12,
residence_livable = V13
) %>%
mutate(across(c(total_total, total_good, total_livable, total_dilapidated,
residence_total, residence_good, residence_livable),
~as.numeric(gsub(",", "", .)))) %>%
mutate(state_code       = as.numeric(state_code),
dist_code        = as.numeric(dist_code),
tehsil_city_code = as.numeric(tehsil_city_code)) %>%
filter(!is.na(dist_code), dist_code != 0) %>%
filter(trimws(total_rural_urban) == "Total") %>%
filter(grepl("District", area_name) & !grepl("City", area_name)) %>%
select(dist_code, total_total, total_good, total_livable, total_dilapidated,
residence_total, residence_good, residence_livable) %>%
mutate(pct_dilapidated = total_dilapidated / total_total * 100)
# Chunk 8: final
final <- clean_combine %>%
left_join(riots, by = "dist_code") %>%
mutate(total_muslim_destroyed = Dargah + Masjid + Madresa)
# Chunk 9: summary
summary_df <- final %>%
filter(`MOTHER TONGUE` == "5 GUJARATI") %>%
group_by(dist_code, District) %>%
summarize(
pct_gujarati           = mean(PERCENT,                na.rm = TRUE),
total_muslim_destroyed = mean(total_muslim_destroyed, na.rm = TRUE),
pct_hindu_minus_muslim = mean((hindu_persons - muslim_persons) /
total_persons * 100,  na.rm = TRUE),
total_persons          = sum(total_persons,           na.rm = TRUE),
.groups = "drop"
)
# Chunk 10: manual-districts
summary_df <- summary_df %>%
mutate(
District = case_when(
dist_code == 5  ~ "Bharuch",
dist_code == 23 ~ "Sabarkantha",
dist_code == 26 ~ "Ahwa-Dang",
TRUE ~ District
),
total_muslim_destroyed = case_when(
dist_code == 5  ~ 7,
dist_code == 23 ~ 82,
dist_code == 26 ~ 0,
TRUE ~ total_muslim_destroyed
),
pct_gujarati = case_when(
dist_code == 5  ~ 84.97,
dist_code == 23 ~ 97.85,
TRUE ~ pct_gujarati
),
total_persons = case_when(
dist_code == 5  ~ 1370104,
dist_code == 23 ~ 2083416,
dist_code == 26 ~ 186712,
TRUE ~ total_persons
)
)
# Chunk 11: final-before-capita
new_final <- summary_df %>%
left_join(housing, by = "dist_code") %>%
filter(dist_code != 21)
# Chunk 12: per-capita
new_final <- new_final %>%
mutate(
muslim_destroyed_per_capita    = total_muslim_destroyed / total_persons,
good_housing_per_capita        = total_good             / total_persons,
livable_housing_per_capita     = total_livable          / total_persons,
dilapidated_housing_per_capita = total_dilapidated      / total_persons,
pct_dilapidated                = total_dilapidated      / total_total   * 100
)
# Chunk 13: regression-baseline
regression <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati +
I(pct_hindu_minus_muslim ^ 2) + good_housing_per_capita,
data = new_final)
summary(regression)
plot(regression, which = 1:2)
new_final_no2 <- new_final %>%
filter(dist_code != 2)
regression_no2 <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati +
I(pct_hindu_minus_muslim ^ 2) + good_housing_per_capita,
data = new_final_no2)
summary(regression_no2)
plot(regression_no2, which = 1:2)
regression <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati,
data = new_final)
summary(regression)
regression <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati +
I(pct_hindu_minus_muslim ^ 2),
data = new_final)
summary(regression)
regression <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati +
I(pct_hindu_minus_muslim ^ 2) + good_housing_per_capita,
data = new_final)
summary(regression)
# Chunk 16: data-1991
raw_1991 <- read_excel("1991_gujarat_religion.xlsx", col_names = FALSE, sheet = "C09T")
colnames(raw_1991) <- c(
"table", "state_code", "district_code", "name", "area_type",
"total_pop", "total_male", "total_female",
"hindu", "hindu_male", "hindu_female",
"muslim", "muslim_male", "muslim_female",
"christian", "christian_male", "christian_female",
"sikh", "sikh_male", "sikh_female",
"buddhist", "buddhist_male", "buddhist_female",
"jain", "jain_male", "jain_female",
"other_religion", "other_male", "other_female",
"religion_not_stated", "not_stated_male", "not_stated_female"
)
gujarat_props <- raw_1991 %>%
filter(state_code == "07", district_code != "00", area_type == "Total") %>%
mutate(
district_name = gsub("^District-", "", name) %>% trimws(),
across(c(total_pop, hindu, muslim, christian, sikh,
buddhist, jain, other_religion, religion_not_stated), as.numeric)
) %>%
select(state_code, district_code, district_name, total_pop,
hindu, muslim, christian, sikh, buddhist, jain,
other_religion, religion_not_stated) %>%
mutate(
prop_hindu          = hindu            / total_pop,
prop_muslim         = muslim           / total_pop,
prop_christian      = christian        / total_pop,
prop_sikh           = sikh             / total_pop,
prop_buddhist       = buddhist         / total_pop,
prop_jain           = jain             / total_pop,
prop_other_religion = other_religion   / total_pop,
prop_not_stated     = religion_not_stated / total_pop
)
gujarat_religion_proportions <- gujarat_props %>%
select(district_code, district_name, total_pop, starts_with("prop_"))
print(gujarat_religion_proportions, n = Inf)
# Chunk 17: comparison-1991-2001
districts_1991_urban <- raw_1991 %>%
filter(state_code == "07", district_code != "00", area_type == "Urban") %>%
mutate(
district_name = gsub("^District-", "", name) %>% trimws(),
across(c(total_pop, muslim), as.numeric)
) %>%
select(district_name, muslim_1991 = muslim, total_pop_1991 = total_pop) %>%
mutate(pct_muslim_1991 = muslim_1991 / total_pop_1991 * 100)
dist_code_to_name <- c(
"1"  = "Amreli",       "2"  = "Anand",        "3"  = "Bhavnagar",
"4"  = "Banas Kantha", "5"  = "Bharuch",       "6"  = "Gandhinagar",
"7"  = "Ahmadabad",    "8"  = "Dahod",         "9"  = "Junagadh",
"10" = "Kheda",        "11" = "Jamnagar",      "12" = "Kachchh",
"13" = "Mahesana",     "14" = "Narmada",       "15" = "Navsari",
"16" = "Panch Mahals", "17" = "Patan",         "18" = "Surat",
"19" = "Vadodara",     "20" = "Porbandar",     "21" = "Rajkot",
"22" = "Sabar Kantha", "23" = "Surendranagar", "24" = "Valsad",
"25" = "The Dangs"
)
districts_2001_urban <- religion_clean %>%
group_by(dist_code) %>%
summarise(
muslim_2001    = sum(muslim_persons, na.rm = TRUE),
total_pop_2001 = sum(total_persons,  na.rm = TRUE),
.groups = "drop"
) %>%
mutate(district_name = dist_code_to_name[as.character(dist_code)]) %>%
filter(!is.na(district_name)) %>%
mutate(district_name = case_when(
district_name == "Anand"     ~ "Kheda",
district_name == "Dahod"     ~ "Panch Mahals",
district_name == "Narmada"   ~ "Bharuch",
district_name == "Navsari"   ~ "Valsad",
district_name == "Porbandar" ~ "Junagadh",
district_name == "Patan"     ~ "Banas Kantha",
TRUE ~ district_name
)) %>%
group_by(district_name) %>%
summarise(
muslim_2001    = sum(muslim_2001,    na.rm = TRUE),
total_pop_2001 = sum(total_pop_2001, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(pct_muslim_2001 = muslim_2001 / total_pop_2001 * 100)
comparison <- districts_1991_urban %>%
inner_join(districts_2001_urban, by = "district_name") %>%
mutate(pct_muslim_change = pct_muslim_2001 - pct_muslim_1991) %>%
select(district_name, pct_muslim_1991, pct_muslim_2001, pct_muslim_change,
muslim_1991, muslim_2001, total_pop_1991, total_pop_2001)
print(comparison)
# Chunk 18: add-muslim-change
name_to_code_1991 <- c(
"Amreli"        = 1,  "Bhavnagar"     = 3,  "Banas Kantha"  = 4,
"Bharuch"       = 5,  "Gandhinagar"   = 6,  "Ahmadabad"     = 7,
"Junagadh"      = 9,  "Kheda"         = 10, "Jamnagar"      = 11,
"Kachchh"       = 12, "Mahesana"      = 13, "Panch Mahals"  = 16,
"Surat"         = 18, "Vadodara"      = 19, "Rajkot"        = 21,
"Sabar Kantha"  = 22, "Surendranagar" = 24, "Valsad"        = 25,
"The Dangs"     = 26
)
parent_code <- c(
"1"  = 1,  "2"  = 10, "3"  = 3,  "4"  = 4,  "5"  = 5,
"6"  = 6,  "7"  = 7,  "8"  = 16, "9"  = 9,  "10" = 10,
"11" = 11, "12" = 12, "13" = 13, "14" = 5,  "15" = 25,
"16" = 16, "17" = 4,  "18" = 18, "19" = 19, "20" = 9,
"21" = 21, "22" = 22, "23" = 24, "24" = 25, "25" = 26, "26" = 26
)
comparison_coded <- comparison %>%
mutate(
pct_muslim_change = pct_muslim_2001 - pct_muslim_1991,
dist_code_1991    = name_to_code_1991[district_name]
) %>%
filter(!is.na(dist_code_1991)) %>%
select(dist_code_1991, pct_muslim_change, pct_muslim_1991, pct_muslim_2001)
all_2001_codes <- tibble(
dist_code      = as.integer(names(parent_code)),
dist_code_1991 = as.integer(parent_code)
)
comparison_expanded <- all_2001_codes %>%
left_join(comparison_coded, by = "dist_code_1991") %>%
select(dist_code, pct_muslim_change, pct_muslim_1991, pct_muslim_2001)
new_final <- new_final %>%
left_join(comparison_expanded, by = "dist_code")
# Verify no NAs
new_final %>%
select(dist_code, District, pct_muslim_change) %>%
filter(is.na(pct_muslim_change))
# Chunk 19: muslim-change-summary
mean(new_final$pct_muslim_change, na.rm = TRUE)
new_final %>%
summarise(
weighted_change = weighted.mean(pct_muslim_change, total_persons, na.rm = TRUE)
)
new_final %>%
select(District, pct_muslim_1991, pct_muslim_2001, pct_muslim_change) %>%
arrange(pct_muslim_change) %>%
print(n = Inf)
# Chunk 20: regression-full
regression <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati +
I(pct_hindu_minus_muslim ^ 2) + good_housing_per_capita +
pct_muslim_change,
data = new_final)
summary(regression)
plot(regression, which = 1:2)
interaction <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati, data = new_final)
summary(interaction)
interaction <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_muslim_change, data = new_final)
summary(interaction)
interaction <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati + I(pct_hindu_minus_muslim ^ 2), data = new_final)
summary(interaction)
interaction <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_muslim_change + I(pct_hindu_minus_muslim ^ 2), data = new_final)
summary(interaction)
interaction <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati + I(pct_hindu_minus_muslim ^ 2)+ good_housing_per_capita, data = new_final)
summary(interaction)
interaction <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_muslim_change + I(pct_hindu_minus_muslim ^ 2)+ good_housing_per_capita, data = new_final)
summary(interaction)
interaction <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati + pct_muslim_change + I(pct_hindu_minus_muslim ^ 2)+ good_housing_per_capita, data = new_final)
summary(interaction)
plot(interaction, which = 1:2)
regression <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati,
data = new_final)
summary(regression)
regression <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_muslim_change,
data = new_final)
summary(regression)
regression <- lm(I(muslim_destroyed_per_capita * 100000) ~ 1 + pct_gujarati + pct_muslim_change,
